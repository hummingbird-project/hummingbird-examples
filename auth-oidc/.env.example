# Copy to .env and fill in values for your OIDC provider.
# Never commit .env to source control.

# Issuer URL — the base URL of your OIDC provider
# Google:        https://accounts.google.com
# Microsoft:     https://login.microsoftonline.com/<tenant>/v2.0
# Auth0:         https://<your-tenant>.auth0.com
# Keycloak:      http://localhost:8081/realms/<realm>
OIDC_ISSUER=https://accounts.google.com

# OAuth 2.0 client credentials from your provider's dashboard
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret

# Must exactly match a redirect URI registered with your provider
OIDC_REDIRECT_URI=http://localhost:8080/auth/callback
